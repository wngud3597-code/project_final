KMA_SERVICE_KEY=
HOST=127.0.0.1
PORT=8000
CHAT_MODE=auto

# 선택 사항: 기본 auto 모드는 키가 있으면 OpenAI, 없으면 무료 안내 모드를 사용합니다.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.6-luna

# USAGE
# 1) 로컬에서 날씨 API를 사용하려면 이 파일을 복사하여 `backend/.env`를 만들고
#    `KMA_SERVICE_KEY`에 실제 키를 입력하세요. 예:
#      cd backend
#      copy .env.example .env
#      notepad .env
#    Windows에서는 `backend\open-weather-key.cmd`를 실행하면 동일한 작업을 도와줍니다.
# 2) 백엔드의 `backend/.env` 파일은 보안을 위해 Git에서 무시됩니다 (루트 .gitignore에 설정).
# 3) 배포 환경에서는 레포지토리에 키를 넣지 말고, Netlify/GitHub Actions 등의
#    환경 변수(Secrets) 설정을 사용하세요.
